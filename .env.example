# ============================================
# RESUMAI ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# HUGGING FACE (REQUIRED)
# ============================================
# Get your free API token at: https://huggingface.co/settings/tokens
# Required for CV generation, chat, and cover letter features
HF_API_TOKEN=your_huggingface_token_here

# Model selection (optional, defaults to Mistral-7B)
# Recommended options:
#   - mistralai/Mistral-7B-Instruct-v0.3 (fast, good quality) [DEFAULT]
#   - meta-llama/Meta-Llama-3-8B-Instruct (higher quality, slower)
#   - microsoft/Phi-3-mini-4k-instruct (fastest, smaller model)
#   - HuggingFaceH4/zephyr-7b-beta (good for instructions)
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ============================================
# SECURITY
# ============================================
# JWT secret for authentication (generate a random 32+ character string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_a_strong_random_secret_here

# Environment (development or production)
NODE_ENV=development

# ============================================
# SERVER
# ============================================
PORT=3001

# ============================================
# GOOGLE OAUTH (OPTIONAL)
# ============================================
# For Google Sign-In functionality
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here

# ============================================
# FRONTEND (for Vite)
# ============================================
# These are prefixed with VITE_ to be available in frontend
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ============================================
# DISABLED FEATURES
# ============================================
# Ollama is disabled - using Hugging Face instead
OLLAMA_ENABLED=false

# Mock jobs disabled in production
USE_MOCK_JOBS=false
